# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agroinsight_dev
POSTGRES_PORT=5434

# Primary app database url (development)
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/agroinsight_dev

# Test database (used by CI/test runner)
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/agroinsight_test


# Auth and app
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-at-least-32-chars-long-for-security-reasons
JWT_ACCESS_SECRET=access-secret-minimum-32-chars
JWT_REFRESH_SECRET=refresh-secret-minimum-32-chars

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-firebase-auth-domain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-firebase-storage-bucket
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-firebase-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your-firebase-measurement-id

# Weather provider
WEATHERAI_API_KEY=your-weatherai-key

# Cron token for internal endpoints
VERCEL_CRON_TOKEN=local-cron-token
